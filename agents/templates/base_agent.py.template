def execute_shell_command(command):
    """Execute shell command"""
    try:
        result = subprocess.run(
            command,
            shell=True,
            capture_output=True,
            text=True,
            timeout=30
        )
        return result.stdout, result.stderr if result.returncode != 0 else None
    except subprocess.TimeoutExpired:
        return None, "Command timed out after 30 seconds"
    except Exception as e:
        return None, str(e)

{{FEATURE_MODULES}}

def execute_task(task):
    """
    Execute a task based on its type.
    
    Returns: (output, error, execution_time)
    """
    task_type = task.get("task_type")
    command = task.get("command")
    
    print(f"  📋 Executing: {task_type}")
    
    start_time = time.time()
    output = None
    error = None
    
    try:
        if task_type == "shell":
            output, error = execute_shell_command(command)
        
        {{FEATURE_EXECUTION}}
        
        else:
            error = f"Unsupported task type: {task_type}"
    
    except Exception as e:
        error = str(e)
    
    execution_time = time.time() - start_time
    
    return output, error, execution_time

