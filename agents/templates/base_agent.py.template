def calculate_sleep_time():
    """Calculate sleep time with jitter"""
    if JITTER > 0:
        variation = SLEEP_INTERVAL * JITTER
        return random.uniform(
            SLEEP_INTERVAL - variation,
            SLEEP_INTERVAL + variation
        )
    return SLEEP_INTERVAL

